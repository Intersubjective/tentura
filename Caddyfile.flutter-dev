# Same as Caddyfile, but the default site proxies to Flutter's web dev server
# (flutter run -d web-server) instead of serving static files from /srv/web.
# Use with: docker compose -f compose.dev.yaml -f compose.flutter-dev.yaml up -d
# Then: cd packages/client && flutter run -d web-server --web-port=${FLUTTER_DEV_PORT:-8888} \
#   --dart-define=SERVER_NAME=https://localhost
{
	auto_https disable_redirects
	# host network: avoid conflict if another Caddy (or stale bind) uses :2019
	admin off
}

{$SERVER_NAME:localhost} {
	tls {$ACME_EMAIL}

	request_body {
		max_size {$CLIENT_MAX_BODY_SIZE:1MB}
	}

	encode gzip

	# Multipart /api/v1/graphql -> Tentura at /api/v2/graphql
	@multipart_v1 {
		path /api/v1/graphql
		header Content-Type *multipart*
	}
	handle @multipart_v1 {
		rewrite * /api/v2/graphql
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Non-multipart /api/v1/graphql -> Hasura at /v1/graphql
	handle /api/v1/graphql {
		rewrite * /v1/graphql
		reverse_proxy {$HASURA_UPSTREAM:hasura:8080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Tentura GraphQL and WebSocket (long timeouts for subscriptions)
	handle /api/v2/graphql {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}
	handle /api/v2/ws {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Tentura: service worker and shared assets
	handle /firebase-messaging-sw.js {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}
	handle /shared/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}

	# Hasura: strip /api prefix (e.g. /api/ -> Hasura /)
	handle_path /api/* {
		reverse_proxy {$HASURA_UPSTREAM:hasura:8080}
	}

	# Optional: pgAdmin (omit if pgadmin service not running)
	handle /pgadmin4/* {
		reverse_proxy pgadmin:80 {
			header_up X-Script-Name /pgadmin4
		}
	}

	# Flutter web dev server (hot reload, DTD) and CORS/security headers.
	# packages/client/web_dev_config.yaml serves HTTPS on this port; proxy must use https://
	# and skip TLS verify for the local dev certificate in .cert/
	handle {
		reverse_proxy https://localhost:{$FLUTTER_DEV_PORT:8888} {
			transport http {
				tls_insecure_skip_verify
			}
		}
		header Cross-Origin-Opener-Policy "same-origin"
		header Cross-Origin-Embedder-Policy "credentialless"
		header Access-Control-Allow-Credentials "false"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Origin "{$CORS:*}"
	}
}
