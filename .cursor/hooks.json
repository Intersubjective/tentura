{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": ".cursor/hooks/vexp-guard.sh",
        "matcher": "^(Grep|Glob)$"
      }
    ],
    "afterShellExecution": [
      {
        "command": ".cursor/hooks/ollama-compress.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/rag-reindex-dart.sh"
      }
    ]
  }
}
