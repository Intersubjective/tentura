# Copy to .env and adjust. Used by Docker Compose and by scripts/run-server-local.sh.
#
# VPS / production: all secrets here. compose.prod.yaml passes variable names through;
# compose.override.yaml (optional, per-host) holds non-secret structural deltas only.
# See examples/compose.override.example.yaml.
#
# Required for local single-host web stack (validate with ./scripts/resolve_local_web_config.sh --check-only):
#   SERVER_NAME (public origin URL), IMAGE_SERVER
# When GOOGLE_CLIENT_ID is set, GOOGLE_CLIENT_SECRET is also required.

POSTGRES_PASSWORD=password

JWT_PUBLIC_PEM=-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEA2CmIb3Ho2eb6m8WIog6KiyzCY05sbyX04PiGlH5baDw=\n-----END PUBLIC KEY-----\n
JWT_PRIVATE_PEM=-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIN3rCo3wCksyxX4qBYAC1vFr51kx/Od78QVrRLOV1orF\n-----END PRIVATE KEY-----\n

# Hasura (VPS). Local dev uses compose.dev.yaml defaults instead.
# HASURA_GRAPHQL_ADMIN_SECRET=
# HASURA_GRAPHQL_CORS_DOMAIN=https://dev.example.com,https://app.dev.example.com

# Caddy / proxy (VPS). SERVER_NAME in override may differ from Tentura public origin URL.
# ACME_EMAIL=cert@example.com
# APP_HOST=app.dev.example.com
# APP_ROOT=/srv/web
# LANDING_ROOT=/srv/landing

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DBNAME=postgres
POSTGRES_USERNAME=postgres
# VPS Tentura container (optional override; default in compose.prod is unset → Env default 10)
# POSTGRES_MAXCONN=20

HOST=0.0.0.0
PORT=2080
# Public origin (app + landing + API via Caddy). Also used for OG/share URLs and OAuth callbacks.
SERVER_NAME=https://dev.lvh.me:9443
# Local Caddy root split: default-on in Caddyfile.local (signed-out `/` → landing). Set off for raw app-at-root dev.
# LOCAL_ROOT_SPLIT=off
DEBUG_MODE=true
NEED_INVITE=false
PRINT_ENV=true
WORKERS_COUNT=2
# LOG_LEVEL=all

# OAuth / session — HTTPS :9443 required for __Host- cookies (Caddyfile.local, tls internal).
# Google Console redirect URI: https://dev.lvh.me:9443/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email magic-link auth (Resend). Empty = email start no-ops (generic ok still returned).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Tentura <auth@yourdomain.com>
# EMAIL_AUTH_TTL_SECONDS=900
# DEV ONLY — NEVER set in production. Writes magic links to <dir>/<email>.json
# instead of sending email (takes precedence over Resend); enables local and
# automated e2e signup flows without a mailbox.
# EMAIL_DEBUG_SINK_DIR=.local/email-sink
# QA / automated browser-agent testing (remote dev / agents).
# DEV/STAGING ONLY. NEVER set in production. Requires ENVIRONMENT=dev.
# Independent of EMAIL_DEBUG_SINK_DIR (local file sink). When enabled with
# QA_AUTH_TOKEN, exposes GET /_qa/latest-email and captures magic links for
# QA_EMAIL_DOMAINS to /tmp/tentura-qa-email-capture (writable in the container).
# QA_AUTH_ENABLED=true
# QA_AUTH_TOKEN=
# QA_EMAIL_DOMAINS=test.tentura.local,qa.tentura.local,example.test
# Notification emails (digest + immediate "asked of you").
# HMAC secret for one-click unsubscribe links (required for email notifications).
# UNSUBSCRIBE_SIGNING_SECRET=
# Min seconds between immediate emails per recipient+category (anti-flood).
# EMAIL_NOTIF_COOLDOWN_SECONDS=1800
# Local hour-of-day (0-23) the daily/weekly digest is sent.
# EMAIL_DIGEST_HOUR=8
# When true, Google OAuth start/callback return HTML that warms WASM assets (same origin).
# OAUTH_PRELOAD_ENABLED=true
SESSION_EXPIRES_IN=2592000

# Minimum Tentura client semver accepted by this server.
# Clients older than this show a "new version available" banner.
# 0.0.0 disables the check (any client version is accepted).
# Bump when shipping breaking client changes (e.g. beacon visibility gate in 4.0.0).
MIN_CLIENT_VERSION=4.0.0

# Dirichlet trust-edge junction (user→user MeritRank weights).
# See docs/features/trust_edges.md for meritrank_sweep, trust_recompute_all, etc.
# TRUST_EDGE_HALF_LIFE_DAYS=182
# TRUST_EDGE_EPSILON=0.1

# S3-compatible storage (MinIO in dev). S3_ENDPOINT may be host or host:port.
# S3_USE_SSL=false matches plain HTTP on :9000; use true for HTTPS endpoints.
S3_ENDPOINT=localhost:9000
S3_BUCKET=tentura
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PATH_STYLE=true
# Omit for MinIO on :9000 (defaults to HTTP). Set true for HTTPS S3/Spaces.
# If unset, TLS is inferred for *.digitaloceanspaces.com and *.amazonaws.com.
S3_USE_SSL=false
# Optional. PutObject ACL: omit / none / false = no x-amz-acl (then add a bucket policy
# so CDN/browser can GET images/*). If unset: public-read (anonymous avatar/beacon URLs).
#S3_OBJECT_ACL=omit
IMAGE_SERVER=http://localhost:9000/tentura

# Firebase Cloud Messaging (server-side push). FB_PRIVATE_KEY: PEM with \n escapes.
# Server push requires all three: FB_PROJECT_ID, FB_CLIENT_EMAIL, FB_PRIVATE_KEY.
# If any is missing, push is mocked and a startup warning is logged.
# Client / service-worker vars (FB_API_KEY, FB_APP_ID, …) are separate; a working
# firebase-messaging-sw.js does not imply server push is enabled.
# FB_PROJECT_ID=
# FB_SENDER_ID=
# FB_AUTH_DOMAIN=
# FB_STORAGE_BUCKET=
# FB_API_KEY=
# FB_APP_ID=
# FB_CLIENT_EMAIL=
# FB_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# pgAdmin (optional; enable via compose.override.yaml)
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=
