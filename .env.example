# Copy to .env and adjust. Used by Docker Compose and by scripts/run-server-local.sh.
#
# Required for local single-host web stack (validate with ./scripts/resolve_local_web_config.sh --check-only):
#   SERVER_NAME (public origin URL), IMAGE_SERVER
# When GOOGLE_CLIENT_ID is set, GOOGLE_CLIENT_SECRET is also required.

POSTGRES_PASSWORD=password

JWT_PUBLIC_PEM=-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEA2CmIb3Ho2eb6m8WIog6KiyzCY05sbyX04PiGlH5baDw=\n-----END PUBLIC KEY-----\n
JWT_PRIVATE_PEM=-----BEGIN PRIVATE KEY-----\nMC4CAQAwBQYDK2VwBCIEIN3rCo3wCksyxX4qBYAC1vFr51kx/Od78QVrRLOV1orF\n-----END PRIVATE KEY-----\n

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DBNAME=postgres
POSTGRES_USERNAME=postgres

HOST=0.0.0.0
PORT=2080
# Public origin (app + landing + API via Caddy). Also used for OG/share URLs and OAuth callbacks.
SERVER_NAME=https://dev.lvh.me:9443
DEBUG_MODE=true
NEED_INVITE=false
PRINT_ENV=true
WORKERS_COUNT=2

# OAuth / session — HTTPS :9443 required for __Host- cookies (Caddyfile.local, tls internal).
# Google Console redirect URI: https://dev.lvh.me:9443/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email magic-link auth (Resend). Empty = email start no-ops (generic ok still returned).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Tentura <auth@yourdomain.com>
# EMAIL_AUTH_TTL_SECONDS=900
# When true, Google OAuth start/callback return HTML that warms WASM assets (same origin).
# OAUTH_PRELOAD_ENABLED=true
SESSION_EXPIRES_IN=2592000

# Minimum Tentura client semver accepted by this server.
# Clients older than this show a "new version available" banner.
# 0.0.0 disables the check (any client version is accepted).
MIN_CLIENT_VERSION=2.0.0

# S3-compatible storage (MinIO in dev). S3_ENDPOINT may be host or host:port.
# S3_USE_SSL=false matches plain HTTP on :9000; use true for HTTPS endpoints.
S3_ENDPOINT=localhost:9000
S3_BUCKET=tentura
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PATH_STYLE=true
# Omit for MinIO on :9000 (defaults to HTTP). Set true for HTTPS S3/Spaces.
# If unset, TLS is inferred for *.digitaloceanspaces.com and *.amazonaws.com.
S3_USE_SSL=false
# Optional. PutObject ACL: omit / none / false = no x-amz-acl (then add a bucket policy
# so CDN/browser can GET images/*). If unset: public-read (anonymous avatar/beacon URLs).
#S3_OBJECT_ACL=omit
IMAGE_SERVER=http://localhost:9000/tentura
