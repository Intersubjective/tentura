# Single public origin (Phase 1):
#   {$SERVER_NAME} -> /invite/* static landing (no COOP/COEP), / WASM app (COOP/COEP), /api/* unchanged
#
# VPS .env: SERVER_NAME=dev.tentura.io (site hostname), APP_ROOT=/srv/web,
#   LANDING_ROOT=/srv/landing, ACME_EMAIL=...
{
	auto_https disable_redirects
	admin off
}

(api) {
	# /api/v1/graphql -> Hasura at /v1/graphql
	handle /api/v1/graphql {
		rewrite * /v1/graphql
		reverse_proxy {$HASURA_UPSTREAM:hasura:8080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	handle /api/v2/graphql {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}
	handle /api/v2/ws {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	handle /api/v2/room-attachments/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Invite preview (Phase 0) — must hit Tentura, not Hasura catch-all below.
	handle /api/v2/invite/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Session cookie endpoints (TMB) — must hit Tentura, not Hasura catch-all below.
	handle /api/v2/session/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Google OAuth on app host — must hit Tentura, not Hasura catch-all below.
	handle /api/auth/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Email magic-link start (Phase 2) + verify path on public host.
	handle /api/v2/auth/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}
	handle /auth/email/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Development/staging-only QA endpoints enforce their own hidden token guard.
	handle /_qa/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}

	# Credential management (Phase 1) — must hit Tentura, not Hasura catch-all below.
	handle /api/v2/accounts/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	handle /firebase-messaging-sw.js {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}
	handle /shared/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}

	handle_path /api/* {
		reverse_proxy {$HASURA_UPSTREAM:hasura:8080}
	}
}

# Single host — invite static shell + WASM app + API (same origin).
{$SERVER_NAME:localhost} {
	tls {$ACME_EMAIL:internal}

	request_body {
		max_size {$CLIENT_MAX_BODY_SIZE:12MB}
	}

	encode gzip

	import api

	handle /pgadmin4/* {
		reverse_proxy pgadmin:80 {
			header_up X-Script-Name /pgadmin4
		}
	}

	# Static invite shell — NO COOP/COEP. Prefix strip keeps assets under /invite/*.
	handle_path /invite/* {
		root * {$LANDING_ROOT:/srv/landing}
		try_files {path} /index.html
		file_server
		header Access-Control-Allow-Origin "{$CORS:*}"
	}

	# Signed-out `/` serves landing index.html with relative *.js / *.css at site root.
	@landing_static_file {
		path *.js *.css
		file {
			root {$LANDING_ROOT:/srv/landing}
			try_files {path}
		}
	}
	handle @landing_static_file {
		root * {$LANDING_ROOT:/srv/landing}
		file_server
	}

	handle_errors {
		@e404 expression {http.error.status_code} == 404
		handle @e404 {
			respond "Service is being deployed. Please try again shortly." 503
		}
	}

	# Service worker + preload manifest must always revalidate so a new deploy's
	# cache version is picked up on a normal refresh (not only a hard refresh).
	@appUpdateFiles path /index.html /flutter_bootstrap.js /google_maps_config.js /manifest.json /tentura-app-cache-sw.js /version.json /wasm-preload-manifest.json

	# Versioned Flutter app assets are immutable and safe for long CDN/browser TTLs.
	@appImmutableAssets path /app-assets/*
	handle @appImmutableAssets {
		root * {$APP_ROOT:/srv/web}
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
		header Cross-Origin-Opener-Policy "same-origin"
		header Cross-Origin-Embedder-Policy "credentialless"
		header Access-Control-Allow-Credentials "false"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Origin "{$CORS:*}"
	}

	# Public root: cookie present → WASM; absent → landing (Level 1).
	@rootWithSession {
		path /
		header Cookie *__Host-tentura_session=*
	}
	@publicRoot {
		path /
	}
	handle @rootWithSession {
		root * {$APP_ROOT:/srv/web}
		try_files {path} /index.html
		file_server
		header Cross-Origin-Opener-Policy "same-origin"
		header Cross-Origin-Embedder-Policy "credentialless"
		header Vary "Cookie"
		header Cache-Control "no-store"
	}
	handle @publicRoot {
		root * {$LANDING_ROOT:/srv/landing}
		try_files {path} /index.html
		file_server
		header Vary "Cookie"
		header Cache-Control "no-store"
	}

	# WASM app catch-all — COOP/COEP scoped here only.
	handle {
		root * {$APP_ROOT:/srv/web}
		try_files {path} /index.html
		header @appUpdateFiles Cache-Control "no-cache"
		file_server
		header Cross-Origin-Opener-Policy "same-origin"
		header Cross-Origin-Embedder-Policy "credentialless"
		header Access-Control-Allow-Credentials "false"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Origin "{$CORS:*}"
	}
}
