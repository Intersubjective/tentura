# Subdomain split (dev mimics prod):
#   {$SERVER_NAME}     -> static landing (dev.tentura.io / tentura.io)
#   {$APP_HOST}        -> Flutter WASM app + /api/* + /shared/* (app.dev.tentura.io / app.tentura.io)
#
# VPS .env: SERVER_NAME=https://dev.tentura.io, APP_HOST=app.dev.tentura.io,
#   APP_ROOT=/srv/web, LANDING_ROOT=/srv/landing, ACME_EMAIL=...
# Client build uses CLIENT_SERVER_NAME=https://app.dev.tentura.io (see pipeline.yml).
{
	auto_https disable_redirects
	admin off
}

(api) {
	# /api/v1/graphql -> Hasura at /v1/graphql
	handle /api/v1/graphql {
		rewrite * /v1/graphql
		reverse_proxy {$HASURA_UPSTREAM:hasura:8080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	handle /api/v2/graphql {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}
	handle /api/v2/ws {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	handle /api/v2/room-attachments/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Invite preview (Phase 0) — must hit Tentura, not Hasura catch-all below.
	handle /api/v2/invite/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080} {
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	handle /firebase-messaging-sw.js {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}
	handle /shared/* {
		reverse_proxy {$TENTURA_UPSTREAM:tentura:2080}
	}

	handle_path /api/* {
		reverse_proxy {$HASURA_UPSTREAM:hasura:8080}
	}
}

# Landing host — no COOP/COEP (fast TTI in webviews).
{$SERVER_NAME:localhost} {
	tls {$ACME_EMAIL:internal}

	request_body {
		max_size {$CLIENT_MAX_BODY_SIZE:12MB}
	}

	encode gzip

	@invite_shared_browser {
		path /shared/view
		expression `{http.request.uri.query.id}.startsWith("I")`
		header User-Agent *Mozilla*
	}
	redir @invite_shared_browser https://{$SERVER_NAME}/invite/{http.request.uri.query.id} 302

	import api

	handle /pgadmin4/* {
		reverse_proxy pgadmin:80 {
			header_up X-Script-Name /pgadmin4
		}
	}

	# Empty or missing landing files → friendly page instead of bare 404.
	handle_errors {
		@landing_404 expression {http.error.status_code} == 404
		handle @landing_404 {
			respond "Landing is being deployed. Please try again shortly." 503
		}
	}

	handle {
		root * {$LANDING_ROOT:/srv/landing}
		try_files {path} /index.html
		file_server
		header Access-Control-Allow-Origin "{$CORS:*}"
	}
}

# WASM app host — base-href /; COOP/COEP scoped here only (Risk #1).
{$APP_HOST:app.localhost} {
	tls {$ACME_EMAIL:internal}

	request_body {
		max_size {$CLIENT_MAX_BODY_SIZE:12MB}
	}

	encode gzip

	@invite_shared_browser {
		path /shared/view
		expression `{http.request.uri.query.id}.startsWith("I")`
		header User-Agent *Mozilla*
	}
	redir @invite_shared_browser https://{$SERVER_NAME}/invite/{http.request.uri.query.id} 302

	import api

	handle {
		root * {$APP_ROOT:/srv/web}
		try_files {path} /index.html
		file_server
		header Cross-Origin-Opener-Policy "same-origin"
		header Cross-Origin-Embedder-Policy "credentialless"
		header Access-Control-Allow-Credentials "false"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Origin "{$CORS:*}"
	}
}
