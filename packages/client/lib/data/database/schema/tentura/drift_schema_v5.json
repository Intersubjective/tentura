  "fixed_sql": [
    {
      "name": "accounts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"accounts\" (\"id\" TEXT NOT NULL, \"display_name\" TEXT NOT NULL DEFAULT '', \"image_id\" TEXT NOT NULL DEFAULT '', \"blur_hash\" TEXT NOT NULL DEFAULT '', \"height\" INTEGER NOT NULL DEFAULT 0, \"width\" INTEGER NOT NULL DEFAULT 0, \"fcm_token_updated_at\" TEXT NULL, PRIMARY KEY (\"id\")) WITHOUT ROWID;"
        }
      ]
    },
    {
      "name": "contacts",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"contacts\" (\"account_id\" TEXT NOT NULL, \"subject_id\" TEXT NOT NULL, \"contact_name\" TEXT NOT NULL, \"updated_at\" TEXT NULL, PRIMARY KEY (\"account_id\", \"subject_id\")) WITHOUT ROWID;"
        }
      ]
    },
    {
      "name": "friends",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"friends\" (\"subject_id\" TEXT NOT NULL, \"object_id\" TEXT NOT NULL, \"display_name\" TEXT NOT NULL DEFAULT '', \"image_id\" TEXT NOT NULL DEFAULT '', \"blur_hash\" TEXT NOT NULL DEFAULT '', \"height\" INTEGER NOT NULL DEFAULT 0, \"width\" INTEGER NOT NULL DEFAULT 0, PRIMARY KEY (\"subject_id\", \"object_id\")) WITHOUT ROWID;"
        }
      ]
    },
    {
      "name": "settings",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"settings\" (\"key\" TEXT NOT NULL, \"value_text\" TEXT NULL, \"value_int\" INTEGER NULL, \"value_bool\" INTEGER NULL CHECK (\"value_bool\" IN (0, 1)), PRIMARY KEY (\"key\")) WITHOUT ROWID;"
        }
      ]
    }
