# Dart-defines for web integration tests (flutter drive -d web-server).
#
# The app under test is served by Flutter's dev server on localhost:8888,
# which also proxies /api/v2, /api/v1/graphql and /_qa to the local backend
# (see web_dev_config.yaml). SERVER_NAME must therefore be the dev-server
# origin itself: the session cookie stays first-party and API calls dodge
# CORS. The dev server cannot proxy WebSockets, so WS goes straight to the
# Tentura API (same-site localhost, the session cookie is still sent).
SERVER_NAME=http://localhost:8888
WS_SERVER_NAME=http://localhost:2080
IMAGE_SERVER=http://localhost:9000/tentura
GOOGLE_MAPS_API_KEY=
