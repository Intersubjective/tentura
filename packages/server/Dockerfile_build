FROM dart:stable AS build

WORKDIR /app

# Copy root package files (tentura_root)
COPY pubspec.yaml pubspec_overrides.yaml ./
COPY lib/ ./lib/

# Copy server package files
COPY packages/server/pubspec.yaml packages/server/pubspec_overrides.yaml ./packages/server/
COPY packages/server/bin ./packages/server/bin
COPY packages/server/lib ./packages/server/lib

# Install root dependencies first
RUN dart pub get

# Install server dependencies
WORKDIR /app/packages/server
RUN dart pub get

# Run codegen
RUN dart run build_runner build -d

# Compile executable
RUN dart compile exe bin/tentura.dart -o bin/tentura

FROM scratch

COPY --from=build /runtime/ /

COPY --from=build /app/packages/server/bin/tentura /

EXPOSE 2080/tcp

USER 33:33

CMD [ "/tentura" ]
